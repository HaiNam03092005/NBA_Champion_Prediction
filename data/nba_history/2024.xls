<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>   <thead> <tr class="over_header"> <th aria-label="" data-stat="" colspan="18" class=" over_header center" style="left: -552px; position: sticky; text-align: right; z-index: 20; border-right: 1px solid rgb(148, 150, 152);"></th> <th aria-label="" data-stat="ff_off" colspan="4" class="over_header center not_sticky">Offense Four Factors</th><th class="not_sticky"></th> <th aria-label="" data-stat="ff_def" colspan="4" class="over_header center not_sticky">Defense Four Factors</th> <th aria-label="" data-stat="" colspan="4" class="over_header center not_sticky"></th> </tr> <tr> <th aria-label="Rk" data-stat="ranker" scope="col" class="ranker poptip sort_default_asc show_partial_when_sorting center" data-tip="Rank">Rk</th> <th aria-label="team" data-stat="team" scope="col" class=" poptip center">Team</th> <th aria-label="Age" data-stat="age" scope="col" class=" poptip sort_default_asc center" data-tip="Player's age on January 31 of the season">Age</th> <th aria-label="Wins" data-stat="wins" scope="col" class=" poptip center" data-tip="Wins">W</th> <th aria-label="Losses" data-stat="losses" scope="col" class=" poptip center" data-tip="Losses">L</th> <th aria-label="PW" data-stat="wins_pyth" scope="col" class=" poptip center" data-tip="Pythagorean wins, i.e., expected wins based on points scored and allowed">PW</th> <th aria-label="PL" data-stat="losses_pyth" scope="col" class=" poptip center" data-tip="Pythagorean losses, i.e., expected losses based on points scored and allowed">PL</th> <th aria-label="Margin of Victory" data-stat="mov" scope="col" class=" poptip center" data-tip="Margin of Victory">MOV</th> <th aria-label="Strength of Schedule" data-stat="sos" scope="col" class=" poptip center" data-tip="Strength of Schedule; a rating of strength of schedule. The rating is denominated in points above/below average, where zero is average.">SOS</th> <th aria-label="Simple Rating System" data-stat="srs" scope="col" class=" poptip center" data-tip="Simple Rating System; a team rating that takes into account average point differential and strength of schedule. The rating is denominated in points above/below average, where zero is average.">SRS</th> <th aria-label="Offensive Rating" data-stat="off_rtg" scope="col" class=" poptip center" data-tip="&lt;b&gt;Offensive Rating&lt;/b&gt;&lt;br&gt;An estimate of points produced (players) or scored (teams) per 100 possessions">ORtg</th> <th aria-label="Defensive Rating" data-stat="def_rtg" scope="col" class=" poptip sort_default_asc center" data-tip="&lt;b&gt;Defensive Rating&lt;/b&gt;&lt;br&gt;An estimate of points allowed per 100 possessions">DRtg</th> <th aria-label="Net Rating" data-stat="net_rtg" scope="col" class=" poptip center" data-tip="Net Rating; an estimate of point differential per 100 possessions.">NRtg</th> <th aria-label="Pace Factor" data-stat="pace" scope="col" class=" poptip center" data-tip="&lt;b&gt;Pace Factor&lt;/b&gt;: An estimate of possessions per 48 minutes">Pace</th> <th aria-label="Free Throw Attempt Rate" data-stat="fta_per_fga_pct" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Free Throw Attempt Rate&lt;/strong&gt;&lt;br&gt;Number of FT Attempts Per FG Attempt">FTr</th> <th aria-label="3-Point Attempt Rate" data-stat="fg3a_per_fga_pct" scope="col" class=" poptip center" data-tip="&lt;strong&gt;3-Point Attempt Rate&lt;/strong&gt;&lt;br&gt;Percentage of FG Attempts from 3-Point Range">3PAr</th> <th aria-label="True Shooting Percentage" data-stat="ts_pct" scope="col" class=" poptip center" data-tip="&lt;strong&gt;True Shooting Percentage&lt;/strong&gt;&lt;br&gt;A measure of shooting efficiency that takes into account 2-point field goals, 3-point field goals, and free throws.">TS%</th> <th aria-label="&nbsp;" data-stat="DUMMY" scope="col" class=" poptip center">&nbsp;</th> <th aria-label="Effective Field Goal Percentage" data-stat="efg_pct" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Effective Field Goal Percentage&lt;/strong&gt;&lt;br&gt;This statistic adjusts for the fact that a 3-point field goal is worth one more point than a 2-point field goal." data-over-header="Offense Four Factors">eFG%</th> <th aria-label="Turnover Percentage" data-stat="tov_pct" scope="col" class=" poptip sort_default_asc center" data-tip="&lt;b&gt;Turnover Percentage&lt;/b&gt;&lt;br&gt;An estimate of turnovers committed per 100 plays." data-over-header="Offense Four Factors">TOV%</th> <th aria-label="Offensive Rebound Percentage" data-stat="orb_pct" scope="col" class=" poptip center" data-tip="&lt;b&gt;Offensive Rebound Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of available offensive rebounds a player grabbed while they were on the floor." data-over-header="Offense Four Factors">ORB%</th> <th aria-label="FT/FGA" data-stat="ft_rate" scope="col" class=" poptip center" data-tip="Free Throws Per Field Goal Attempt" data-over-header="Offense Four Factors">FT/FGA</th> <th aria-label="&nbsp;" data-stat="DUMMY" scope="col" class=" poptip center">&nbsp;</th> <th aria-label="Opponent Effective Field Goal Percentage" data-stat="opp_efg_pct" scope="col" class=" poptip sort_default_asc center" data-tip="Opponent Effective Field Goal Percentage" data-over-header="Defense Four Factors">eFG%</th> <th aria-label="Opponent Turnover Percentage" data-stat="opp_tov_pct" scope="col" class=" poptip center" data-tip="Opponent Turnover Percentage" data-over-header="Defense Four Factors">TOV%</th> <th aria-label="Defensive Rebound Percentage" data-stat="drb_pct" scope="col" class=" poptip center" data-tip="&lt;b&gt;Defensive Rebound Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of available defensive rebounds a player grabbed while they were on the floor." data-over-header="Defense Four Factors">DRB%</th> <th aria-label="FT/FGA" data-stat="opp_ft_rate" scope="col" class=" poptip sort_default_asc center" data-tip="Opponent Free Throws Per Field Goal Attempt" data-over-header="Defense Four Factors">FT/FGA</th> <th aria-label="&nbsp;" data-stat="DUMMY" scope="col" class=" poptip center">&nbsp;</th> <th aria-label="Arena" data-stat="arena_name" scope="col" class=" poptip sort_default_asc center">Arena</th> <th aria-label="Attend." data-stat="attendance" scope="col" class=" poptip center">Attend.</th> <th aria-label="Attend./G" data-stat="attendance_per_g" scope="col" class=" poptip center">Attend./G</th> </tr> </thead> <tbody> <tr data-row="0"><th scope="row" class="right " data-stat="ranker">1</th><td class="left " data-stat="team">Oklahoma City Thunder*</td><td class="right " data-stat="age">24.8</td><td class="right " data-stat="wins">68</td><td class="right " data-stat="losses">14</td><td class="right " data-stat="wins_pyth">68</td><td class="right " data-stat="losses_pyth">14</td><td class="right " data-stat="mov">12.87</td><td class="right " data-stat="sos">-0.16</td><td class="right " data-stat="srs">12.70</td><td class="right " data-stat="off_rtg">120.3</td><td class="right " data-stat="def_rtg">107.5</td><td class="right increase" data-stat="net_rtg">+12.8</td><td class="right " data-stat="pace">100.0</td><td class="right " data-stat="fta_per_fga_pct">.220</td><td class="right " data-stat="fg3a_per_fga_pct">.419</td><td class="right " data-stat="ts_pct">.593</td><td class="right iz" data-stat="DUMMY"></td><td class="right " data-stat="efg_pct">.560</td><td class="right " data-stat="tov_pct">10.3</td><td class="right " data-stat="orb_pct">24.2</td><td class="right " data-stat="ft_rate">.180</td><td class="right iz" data-stat="DUMMY"></td><td class="right " data-stat="opp